# OAuth2 Proxy Configuration
# Copy this file to .env and fill in your values

# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: https://tapedeck.us/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=your-client-secret

# Cookie secret (generate with: openssl rand -base64 32)
OAUTH2_PROXY_COOKIE_SECRET=generate-a-32-byte-random-secret

# Allowed email addresses (comma-separated, or use authenticated-emails-file)
# Only these emails can access protected endpoints after Google login
OAUTH2_PROXY_AUTHENTICATED_EMAILS=your-email@gmail.com
